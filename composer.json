{
    "name": "hmennen90/laravel-graphql",
    "description": "A hand-written GraphQL engine with first-class Laravel integration (code-first + SDL).",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "graphql", "api", "schema"],
    "authors": [
        {
            "name": "hmennen90",
            "email": "hmennen90@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/contracts": "^11.0 || ^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Hmennen90\\GraphQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hmennen90\\GraphQL\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hmennen90\\GraphQL\\GraphQLServiceProvider"
            ],
            "aliases": {
                "GraphQL": "Hmennen90\\GraphQL\\Facades\\GraphQL"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:feature": "phpunit --testsuite=Feature",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
