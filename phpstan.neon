includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 10
    paths:
        - src
    excludePaths:
        # Requires the Swoole/OpenSwoole extension (environment-specific, not in CI).
        - src/Subscriptions/Swoole/*
        # Consumer-facing test helper; used in downstream test suites, not internally.
        - src/Testing/MakesGraphQLRequests.php
    tmpDir: build/phpstan
