{
    // Mutation testing focused on the hand-written engine core — the novel,
    // correctness-critical code (lexer, parser, validator, executor, type system).
    // Run with a coverage driver (pcov/xdebug): `composer mutation`.
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "src/Engine"
        ]
    },
    "mutators": {
        "@default": true
    },
    "logs": {
        "text": "build/infection.log",
        "stryker": {
            "badge": "main"
        }
    },
    // Baseline (CI, pcov): 100% mutation coverage, 79% covered MSI on src/Engine.
    // Gates sit just below with headroom for variance; raise as survivors are killed.
    "timeout": 20,
    "minMsi": 72,
    "minCoveredMsi": 75
}
